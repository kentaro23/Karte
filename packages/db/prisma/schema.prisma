// Medixus カルテ — hospital-grade Japanese EMR data model.
// Aligns with Medixus_OS_設計書.html (M01/M04/M06/M12) and the 厚労省 174-item spec.
// Regulatory core: append-only clinical records (電子保存の三原則), provenance-enforced
// drug-safety data (NO AI source — enforced by the DrugDataSource enum type itself),
// hash-chained audit, RBAC + per-patient ACL.

generator client {
  provider      = "prisma-client-js"
  // "native" keeps local dev working on macOS/Linux/Windows; the Vercel
  // serverless target (AWS Lambda / Amazon Linux 2023) needs the
  // rhel-openssl-3.0.x query engine binary or runtime fails with
  // "Cannot find module .prisma/client/default" / engine load errors.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum JobType {
  DOCTOR
  RESIDENT
  NURSE
  PHARMACIST
  CLERK
  TECHNOLOGIST
  THERAPIST
  DIETITIAN
  MANAGER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  UNKNOWN
}

enum ABO {
  A
  B
  O
  AB
  UNKNOWN
}

enum Rh {
  POSITIVE
  NEGATIVE
  UNKNOWN
}

enum EncounterType {
  OUTPATIENT
  INPATIENT
  EMERGENCY
  CHECKUP
  HOMECARE
}

enum VisitType {
  FIRST
  RETURN
}

enum ContactType {
  FACE
  PHONE
  ONLINE
  NON_CONSULT
}

// 診察ステータス — 別紙1 §2.1(17)
enum ReceptionStatus {
  UNRECEIVED
  ARRIVED
  QUESTIONNAIRE_IN_PROGRESS
  QUESTIONNAIRE_DONE
  READY
  IN_CONSULTATION
  SUSPENDED
  CONSULTATION_DONE
  BILLING_DONE
  CANCELLED
  NO_SHOW
}

enum TriageLevel {
  L1_RESUSCITATION
  L2_EMERGENT
  L3_URGENT
  L4_LESS_URGENT
  L5_NON_URGENT
}

enum AppointmentStatus {
  BOOKED
  CONFIRMED
  ARRIVED
  CANCELLED
  NO_SHOW
}

enum NoteType {
  PROGRESS
  NURSING
  NUTRITION
  REPORT
  REHAB
  ER
  ASSESSMENT
  SYMPTOM_DETAIL
  HOMECARE
}

// ClinicalNote / Order version-chain status. SUPERSEDED rows are retained (見読性).
enum RecordStatus {
  EDITING
  SAVED
  LOCKED
  SUPERSEDED
}

enum CountersignStatus {
  UNAPPROVED
  APPROVED
  REJECTED
}

enum StickyScope {
  PRIVATE
  CLINIC_WIDE
}

enum TemplateScope {
  COMMON
  DEPARTMENT
  DOCTOR
}

enum OrderType {
  RX
  INJECTION
  TREATMENT
  LAB
  BACTERIOLOGY
  PATHOLOGY
  PHYSIOLOGY
  RADIOLOGY
  ENDOSCOPY
  DIALYSIS
  REHAB
  GUIDANCE
  CHEMO
  SURGERY
  TRANSFUSION
  MEAL
  REFERRAL
}

// オーダ実施ステータス状態機械
enum OrderStatus {
  DRAFT
  REQUESTED
  RECEIVED
  IN_PROGRESS
  PARTIALLY_DONE
  DONE
  RESULT_ARRIVED
  APPROVED
  CANCELLED
  VOIDED
}

enum DispenseType {
  IN_HOUSE
  OUT_OF_HOUSE
}

enum AllergyType {
  DRUG
  FOOD
  OTHER
}

// ★ Patient-safety boundary, enforced by the type itself: there is NO `AI` / `LLM`
//   member, so the database physically cannot store an AI-sourced safety fact.
enum DrugDataSource {
  MHLW_RECEIPT
  MEDIS
  PMDA_PI_STRUCTURED
  PMDA_PI_XML
  PHARMACIST_VERIFIED
  CURATED_SEED
}

enum DrugTargetKind {
  PRODUCT
  INGREDIENT
}

enum ContraSeverity {
  ABSOLUTE
  RELATIVE
}

enum ContraConditionType {
  DISEASE
  STATE
  AGE
  PREGNANCY
  LACTATION
  LAB
  CO_ADMINISTRATION
  HYPERSENSITIVITY
}

enum InteractionCounterpart {
  DRUG_INGREDIENT
  ATC_CLASS
  FOOD
  DRUG_PRODUCT
}

enum InteractionSeverity {
  CONTRAINDICATED_COMBO
  CAUTION_COMBO
}

enum DosagePopulation {
  ADULT
  PEDIATRIC
  ELDERLY
  NEONATE
  PREGNANT
}

enum RuleCheckType {
  CONTRAINDICATION
  INTERACTION
  DOSE_MAX
  DUPLICATE
  ALLERGY
  DISEASE_CONTRA
  PREGNANCY_LACTATION
  RENAL
  HEPATIC
  AGE
  INFECTION
}

enum RuleResult {
  PASS
  WARNING
  BLOCKED
}

enum RuleCheckedBy {
  STATIC_DB
  PHARMACIST_REVIEW
}

enum AclLevel {
  NO_ACCESS
  PASSWORD_REQUIRED
  VIEW_ONLY
  VIEW_AND_WRITE
}

enum AclScope {
  ALL
  CARE_TEAM_ONLY
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGOUT
  USER_SWITCH
  SCREENSAVER_UNLOCK
  PATIENT_SELECT
  CHART_OPEN
  CHART_VIEW
  CHART_WRITE
  CHART_AMEND
  ORDER_ISSUE
  ORDER_CHECK
  PRESCRIPTION_OVERRIDE
  COUNTERSIGN
  PRINT
  FILE_EXPORT
  RESTRICTED_ACCESS
  MASTER_IMPORT
  PATIENT_MERGE
  // 病床管理 (WRD1) — 入院/退院/転棟・転科・転室
  ADMISSION
  DISCHARGE
  TRANSFER
  // 利用者管理 (ADM1) — アカウント操作 / パスワード初期化・変更
  USER_CREATE
  USER_UPDATE
  USER_DISABLE
  USER_ENABLE
  ACCOUNT_UNLOCK
  PASSWORD_CHANGE
  PASSWORD_RESET
}

enum MasterType {
  DRUG
  DISEASE
  EXAM
  MEDICAL_FEE
  MATERIAL
  GENERIC
}

enum ImportStatus {
  RUNNING
  SUCCESS
  FAILED
  ROLLED_BACK
}

// ── 病床管理 (WRD1) — FR-WRD-01 ──
enum AdmissionStatus {
  ADMITTED
  DISCHARGED
  TRANSFERRED_OUT
  CANCELLED
}

// 病床割当の発生理由（入院初回 / 転棟 / 転科 / 転室 / 退院による解放）。
enum BedMoveReason {
  ADMISSION
  WARD_TRANSFER
  DEPARTMENT_TRANSFER
  ROOM_TRANSFER
  DISCHARGE
}

// ── 看護 (WRD2) — FR-WRD-02 ──
enum NursingPlanStatus {
  ACTIVE
  ACHIEVED
  REVISED
  DISCONTINUED
}

enum NursingPlanItemKind {
  DIAGNOSIS // 看護診断 / 問題
  GOAL // 期待される成果 / 目標
  INTERVENTION_O // O: 観察計画
  INTERVENTION_T // T: ケア計画
  INTERVENTION_E // E: 教育計画
  EVALUATION // 評価
}

// 褥瘡 DESIGN-R®2020 の深さ判定（depth は重症度合計に含めない通則）。
enum PressureUlcerDepth {
  D0 // 皮膚損傷・発赤なし
  D1 // 持続する発赤
  D2 // 真皮までの損傷
  D3 // 皮下組織までの損傷
  D4 // 皮下組織を超える損傷
  D5 // 関節腔・体腔に至る損傷
  DDTI // 深部損傷褥瘡(DTI)疑い
  DU // 深さ判定不能
}

// ── 救急 (ER1) — FR-ER-01 ──
// 同意区分：救急の意識障害等で本人同意が取れない場合の根拠。
enum ConsentType {
  EXPLICIT // 本人の明示同意
  IMPLIED // 黙示の同意 / 緊急避難
  SURROGATE // 家族・代諾者の同意
  EMERGENCY_EXCEPTION // 応急処置（同意取得困難）
}

// ── 在宅 (HOM1) — FR-HOM-01 ──
enum HomeVisitKind {
  DOCTOR // 訪問診療（医師）
  NURSE // 訪問看護
  HOME_CARE_GUIDANCE // 居宅療養管理指導
  REHAB // 訪問リハビリ
  PHARMACIST // 訪問薬剤管理指導
  OTHER
}

// オフライン記録の同期状態（端末キュー → サーバ永続化）。
enum HomeVisitSyncState {
  SYNCED // サーバ確定（オンライン入力 or 同期完了）
  OFFLINE_QUEUED // 端末キュー由来（後追い同期）
}

// ── 処方/オーダセット (RX1/RX2) ──
enum OrderSetKind {
  RX // 処方セット
  ORDER // オーダセット（検査・注射 等の混在）
}

// 用法区分（用法マスタ：内服/頓服/外用）。
enum UsageCategory {
  INTERNAL // 内服
  AS_NEEDED // 頓服
  EXTERNAL // 外用
  INJECTION // 注射
  OTHER
}

// ─────────────────────────────────────────────────────────────────────────────
// Organization
// ─────────────────────────────────────────────────────────────────────────────

model Clinic {
  id        String   @id @default(cuid())
  name      String
  kind      String   @default("CLINIC") // CLINIC | HOSPITAL
  createdAt DateTime @default(now())

  departments Department[]
  wards       Ward[]
  users       StaffUser[]
  patients    Patient[]
}

model Department {
  id        String   @id @default(cuid())
  clinicId  String
  code      String
  name      String
  createdAt DateTime @default(now())
  clinic    Clinic   @relation(fields: [clinicId], references: [id])

  @@unique([clinicId, code])
}

model Ward {
  id       String @id @default(cuid())
  clinicId String
  code     String
  name     String
  clinic   Clinic @relation(fields: [clinicId], references: [id])
  rooms    Room[]

  admissions     Admission[]
  bedAssignments BedAssignment[]

  @@unique([clinicId, code])
}

model Room {
  id           String @id @default(cuid())
  wardId       String
  code         String
  genderPolicy String @default("MIXED") // MALE | FEMALE | MIXED
  ward         Ward   @relation(fields: [wardId], references: [id])
  beds         Bed[]

  bedAssignments BedAssignment[]

  @@unique([wardId, code])
}

model Bed {
  id     String @id @default(cuid())
  roomId String
  code   String
  room   Room   @relation(fields: [roomId], references: [id])

  // 現在この病床にいる受診（在床中の Encounter）。NULL = 空床。
  currentEncounter Encounter?      @relation("BedCurrentEncounter")
  assignments      BedAssignment[]

  @@unique([roomId, code])
}

// ─────────────────────────────────────────────────────────────────────────────
// Identity / Access (M01) — 別紙1 §1, 別紙3 #10-61, 174項 169-174
// ─────────────────────────────────────────────────────────────────────────────

model StaffUser {
  id        String   @id @default(cuid())
  clinicId  String
  staffNo   String   @unique
  loginId   String   @unique
  name      String
  nameKana  String
  jobType   JobType
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  clinic            Clinic                  @relation(fields: [clinicId], references: [id])
  credential        StaffCredential?
  mfaFactors        MfaFactor[]
  sessions          AuthSession[]
  permissions       UserPermission[]
  favorites         UserFavoriteTool[]
  passwordChanges   PasswordChangeHistory[] @relation("PwChangeUser")
  passwordChangesBy PasswordChangeHistory[] @relation("PwChangeActor")

  @@index([clinicId, jobType])
}

model StaffCredential {
  userId         String    @id
  passwordHash   String // Argon2id — never reversible, never plaintext
  validFrom      DateTime  @default(now())
  validTo        DateTime?
  expiresAt      DateTime? // password expiry — 別紙1 §1.1(3)
  mustChange     Boolean   @default(false)
  failedAttempts Int       @default(0)
  lockedAt       DateTime?
  updatedAt      DateTime  @updatedAt
  user           StaffUser @relation(fields: [userId], references: [id])
}

model MfaFactor {
  id        String    @id @default(cuid())
  userId    String
  type      String // TOTP | SMS | PASSKEY
  secret    String
  confirmed Boolean   @default(false)
  createdAt DateTime  @default(now())
  user      StaffUser @relation(fields: [userId], references: [id])
}

model LoginAttempt {
  id         String   @id @default(cuid())
  identifier String
  userId     String?
  success    Boolean
  ip         String?
  terminalId String?
  createdAt  DateTime @default(now())

  @@index([identifier, createdAt])
}

model AuthSession {
  id           String    @id @default(cuid())
  userId       String
  terminalId   String?
  prevLoginAt  DateTime? // 別紙3 #71 — user can self-check last login
  prevTerminal String?
  createdAt    DateTime  @default(now())
  lastSeenAt   DateTime  @default(now())
  expiresAt    DateTime
  revokedAt    DateTime?
  user         StaffUser @relation(fields: [userId], references: [id])

  @@index([userId])
}

// RBAC: job-type matrix + per-user override (別紙3 #35-39)
model RolePermission {
  id       String  @id @default(cuid())
  jobType  JobType
  resource String
  action   String
  allow    Boolean @default(true)

  @@unique([jobType, resource, action])
}

model UserPermission {
  id       String    @id @default(cuid())
  userId   String
  resource String
  action   String
  allow    Boolean
  user     StaffUser @relation(fields: [userId], references: [id])

  @@unique([userId, resource, action])
}

// Per-patient ACL overlay (別紙3 #50-55)
model PatientAccessControl {
  id        String   @id @default(cuid())
  patientId String
  level     AclLevel @default(VIEW_AND_WRITE)
  scope     AclScope @default(ALL)
  jobType   JobType? // null = applies to all
  patient   Patient  @relation(fields: [patientId], references: [id])

  @@index([patientId])
}

// Hash-chained, fully immutable audit log (別紙3 #25-30, 真正性).
// db/triggers.sql forbids UPDATE/DELETE and computes rowHash from prevHash.
model AuditEvent {
  id          String      @id @default(cuid())
  seq         BigInt      @default(autoincrement())
  actorUserId String?
  patientId   String?
  action      AuditAction
  resource    String?
  resourceId  String?
  terminalId  String?
  ip          String?
  result      String      @default("OK")
  detail      Json?
  prevHash    String?
  rowHash     String?
  createdAt   DateTime    @default(now())

  @@index([patientId, createdAt])
  @@index([actorUserId, createdAt])
}

// 排他制御 — 別紙1 §2.9(6), 別紙3 #5-6 / 174項174
model ChartLock {
  id             String   @id @default(cuid())
  resourceType   String // "encounter" | "note"
  resourceId     String
  lockedByUserId String
  lockedByName   String
  terminalId     String
  contact        String?
  lockType       String   @default("WRITE")
  acquiredAt     DateTime @default(now())
  heartbeatAt    DateTime @default(now())

  @@unique([resourceType, resourceId])
}

model UserFavoriteTool {
  id        String    @id @default(cuid())
  userId    String
  toolKey   String
  label     String
  sortOrder Int       @default(0)
  user      StaffUser @relation(fields: [userId], references: [id])

  @@unique([userId, toolKey])
}

model SavedSearchCondition {
  id            String @id @default(cuid())
  userId        String
  screenKey     String
  name          String
  conditionJson Json

  @@index([userId, screenKey])
}

// ─────────────────────────────────────────────────────────────────────────────
// Patient & profile (M01/M02) — 別紙1 §3.5-3.6, 174項 9-15
// ─────────────────────────────────────────────────────────────────────────────

model Patient {
  id              String   @id @default(cuid())
  clinicId        String
  patientNo       String   @unique
  kanaLastName    String
  kanaFirstName   String
  kanjiLastName   String
  kanjiFirstName  String
  formerName      String?
  dateOfBirth     DateTime
  gender          Gender
  bloodTypeABO    ABO      @default(UNKNOWN)
  bloodTypeRh     Rh       @default(UNKNOWN)
  isVip           Boolean  @default(false)
  vipPasswordHash String?
  isTemporaryId   Boolean  @default(false)
  photoUrl        String?
  mergedIntoId    String? // 患者ID統合 (logical, never physical)
  createdAt       DateTime @default(now())

  clinic         Clinic                 @relation(fields: [clinicId], references: [id])
  allergies      Allergy[]
  infections     Infection[]
  histories      MedicalHistory[]
  family         FamilyMember[]
  insurances     Insurance[]
  profile        PatientProfile?
  encounters     Encounter[]
  appointments   Appointment[]
  notes          ClinicalNote[]
  orders         Order[]
  acls           PatientAccessControl[]
  diagnoses      PatientDiagnosis[]
  referrals      Referral[]
  labResults     LabResult[]
  admissions     Admission[]
  bedAssignments BedAssignment[]
  nursingPlans   NursingPlan[]
  pressureUlcers PressureUlcer[]
  homeVisits     HomeVisit[]

  @@index([clinicId])
  @@index([kanaLastName, kanaFirstName])
  @@index([kanjiLastName, kanjiFirstName])
}

model Allergy {
  id             String      @id @default(cuid())
  patientId      String
  type           AllergyType
  substance      String
  ingredientCode String? // links to DrugIngredient for the rule engine
  reaction       String?
  severity       String?
  recordedAt     DateTime    @default(now())
  patient        Patient     @relation(fields: [patientId], references: [id])

  @@index([patientId])
}

model Infection {
  id        String    @id @default(cuid())
  patientId String
  pathogen  String
  status    String
  testedAt  DateTime?
  patient   Patient   @relation(fields: [patientId], references: [id])

  @@index([patientId])
}

model MedicalHistory {
  id         String    @id @default(cuid())
  patientId  String
  kind       String // PAST_ILLNESS | SURGERY | MEDICATION | TRANSFUSION
  name       String
  occurredOn DateTime?
  patient    Patient   @relation(fields: [patientId], references: [id])

  @@index([patientId])
}

model FamilyMember {
  id               String  @id @default(cuid())
  patientId        String
  relation         String
  name             String?
  status           String?
  relatedPatientId String?
  patient          Patient @relation(fields: [patientId], references: [id])

  @@index([patientId])
}

model Insurance {
  id                 String    @id @default(cuid())
  patientId          String
  payerType          String // SOCIAL | NATIONAL | LATE_ELDERLY | SELF_PAY | PUBLIC
  payerNo            String?
  symbol             String?
  number             String?
  branchNo           String? // 被保険者枝番 (2桁) — FR-PAT-04
  publicPayerNo1     String? // 公費1 負担者番号
  publicPayerNo2     String? // 公費2 負担者番号
  publicPayerNo3     String? // 公費3 負担者番号
  publicRecipientNo1 String? // 公費1 受給者番号
  publicRecipientNo2 String? // 公費2 受給者番号
  publicRecipientNo3 String? // 公費3 受給者番号
  workersComp        Boolean   @default(false) // 労災・自賠
  specialNote        String? // 特記事項
  symptomDetail      String? // 症状詳記
  remarksComment     String? // 摘要欄コメント
  validFrom          DateTime?
  validTo            DateTime?
  patient            Patient   @relation(fields: [patientId], references: [id])

  @@index([patientId])
}

model PatientProfile {
  patientId    String   @id
  heightCm     Float?
  weightKg     Float?
  egfr         Float? // renal function for dose adjustment
  hepaticClass String? // CHILD_PUGH_A/B/C
  isPregnant   Boolean  @default(false)
  isLactating  Boolean  @default(false)
  smoking      Json?
  drinking     Json?
  customFields Json?
  updatedAt    DateTime @updatedAt
  patient      Patient  @relation(fields: [patientId], references: [id])
}

model PatientSelectionLog {
  id         String   @id @default(cuid())
  userId     String
  patientId  String
  selectedAt DateTime @default(now())

  @@index([userId, selectedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Scheduling / Reception (M03/M09) — 別紙1 §2, 174項 3-12
// ─────────────────────────────────────────────────────────────────────────────

model AppointmentSlot {
  id           String   @id @default(cuid())
  departmentId String
  doctorUserId String?
  startAt      DateTime
  endAt        DateTime
  capacity     Int      @default(1)

  appointments Appointment[]

  @@index([departmentId, startAt])
}

model Appointment {
  id           String            @id @default(cuid())
  patientId    String
  departmentId String
  doctorUserId String?
  slotId       String?
  scheduledAt  DateTime
  kind         String            @default("CONSULT") // CONSULT | EXAM
  status       AppointmentStatus @default(BOOKED)
  comment      String?
  createdAt    DateTime          @default(now())

  patient   Patient          @relation(fields: [patientId], references: [id])
  slot      AppointmentSlot? @relation(fields: [slotId], references: [id])
  encounter Encounter?

  @@index([departmentId, scheduledAt])
  @@index([patientId])
}

// 受診エピソード — outpatient/inpatient/ER. The chart-level state holder.
model Encounter {
  id              String          @id @default(cuid())
  patientId       String
  appointmentId   String?         @unique
  encounterType   EncounterType
  visitType       VisitType?
  contactType     ContactType     @default(FACE)
  departmentId    String
  wardId          String?
  insuranceId     String?
  receptionNo     Int?
  receptionStatus ReceptionStatus @default(UNRECEIVED)
  triageLevel     TriageLevel?
  arrivalMethod   String?
  // 現在割り当てられている病床 (WRD1)。転室で付け替え、退院で NULL。履歴は BedAssignment。
  currentBedId    String?         @unique
  isTemporaryId   Boolean         @default(false)
  arrivedAt       DateTime?
  openedByUserId  String?
  createdAt       DateTime        @default(now())

  patient        Patient                     @relation(fields: [patientId], references: [id])
  appointment    Appointment?                @relation(fields: [appointmentId], references: [id])
  currentBed     Bed?                        @relation("BedCurrentEncounter", fields: [currentBedId], references: [id])
  sessions       ClinicalSession[]
  orders         Order[]
  transitions    EncounterStatusTransition[]
  labResults     LabResult[]
  admission      Admission?
  bedAssignments BedAssignment[]
  emergencyVisit EmergencyVisit?
  homeVisits     HomeVisit[]

  @@index([receptionStatus, departmentId])
  @@index([patientId])
}

model EncounterStatusTransition {
  id          String          @id @default(cuid())
  encounterId String
  fromStatus  ReceptionStatus
  toStatus    ReceptionStatus
  byUserId    String?
  manual      Boolean         @default(false)
  createdAt   DateTime        @default(now())
  encounter   Encounter       @relation(fields: [encounterId], references: [id])

  @@index([encounterId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Clinical record (M04) — 別紙1 §3, 174項 16-18
// ─────────────────────────────────────────────────────────────────────────────

model ClinicalSession {
  id              String   @id @default(cuid())
  encounterId     String
  recordedDate    DateTime
  departmentId    String
  createdByUserId String
  createdAt       DateTime @default(now())

  encounter Encounter       @relation(fields: [encounterId], references: [id])
  notes     ClinicalNote[]
  record    ClinicalRecord?

  @@index([encounterId, recordedDate])
}

// 記載単位 = the smallest unit of version management.
// APPEND-ONLY: db/triggers.sql blocks content UPDATE and all DELETE.
// Amend = mark old row SUPERSEDED + INSERT new version (previousVersionId chain).
model ClinicalNote {
  id                String       @id @default(cuid())
  sessionId         String
  encounterId       String
  patientId         String
  noteType          NoteType     @default(PROGRESS)
  recordedDate      DateTime
  authorUserId      String
  authorJobType     JobType
  departmentId      String
  wardId            String?
  insuranceId       String?
  isProxyInput      Boolean      @default(false)
  proxyAuthorUserId String?
  responsibleUserId String?
  blocks            Json // [{kind:'S'|'O'|'A'|'P'|'FREE', spans:[{text,marks}]}]
  version           Int          @default(1)
  rootNoteId        String?
  previousVersionId String?      @unique
  supersededById    String?      @unique
  isLatest          Boolean      @default(true)
  status            RecordStatus @default(EDITING)
  lockedAt          DateTime?
  amendReason       String?
  createdAt         DateTime     @default(now())

  session         ClinicalSession  @relation(fields: [sessionId], references: [id])
  patient         Patient          @relation(fields: [patientId], references: [id])
  previousVersion ClinicalNote?    @relation("NoteVersion", fields: [previousVersionId], references: [id])
  nextVersion     ClinicalNote?    @relation("NoteVersion")
  attachments     NoteAttachment[]
  countersign     Countersign?

  @@index([encounterId, recordedDate])
  @@index([patientId, isLatest])
  @@index([rootNoteId, version])
}

model NoteAttachment {
  id           String       @id @default(cuid())
  noteId       String
  kind         String // SCHEMA | TEMPLATE | ORDER_REF | IMAGE | PDF | SCAN | LAB_LINK
  refId        String?
  libraryRef   String? // reference into a shared schema/template library (院内ライブラリ)
  caption      String?
  displayScale Float        @default(1.0)
  sortOrder    Int          @default(0)
  note         ClinicalNote @relation(fields: [noteId], references: [id])

  @@index([noteId])
}

// 研修医カウンターサイン — 別紙3 #60-61
model Countersign {
  id                String            @id @default(cuid())
  noteId            String            @unique
  superviseDoctorId String
  status            CountersignStatus @default(UNAPPROVED)
  approvedAt        DateTime?
  approvedByUserId  String?
  comment           String?
  createdAt         DateTime          @default(now())
  note              ClinicalNote      @relation(fields: [noteId], references: [id])

  @@index([superviseDoctorId, status])
}

model Sticky {
  id              String      @id @default(cuid())
  patientId       String
  encounterId     String?
  title           String
  body            String
  color           String      @default("#fff7df")
  scope           StickyScope @default(PRIVATE)
  createdByUserId String
  createdAt       DateTime    @default(now())

  @@index([patientId])
}

// Session-level confirmed header / SOAP cache. Kept for 設計書 compatibility.
model ClinicalRecord {
  id               String          @id @default(cuid())
  sessionId        String          @unique
  status           String          @default("draft") // draft | approved | locked
  s                String          @default("")
  o                String          @default("")
  a                String          @default("")
  p                String          @default("")
  icd10Codes       String[]        @default([])
  approvedByUserId String?
  approvedAt       DateTime?
  createdAt        DateTime        @default(now())
  session          ClinicalSession @relation(fields: [sessionId], references: [id])
}

model Template {
  id             String        @id @default(cuid())
  scope          TemplateScope @default(COMMON)
  departmentId   String?
  ownerUserId    String?
  category       String
  name           String
  layout         Json
  initialContent Json? // 初期記載内容 (default body inserted on apply)
  conditional    Json? // 条件分岐定義 (show/skip rules)
  version        Int           @default(1)
  createdAt      DateTime      @default(now())

  instances TemplateInstance[]
}

model TemplateInstance {
  id         String   @id @default(cuid())
  templateId String
  noteId     String?
  values     Json
  createdAt  DateTime @default(now())
  template   Template @relation(fields: [templateId], references: [id])
}

// ─────────────────────────────────────────────────────────────────────────────
// Orders & prescription (M04/M06/M07) — 別紙1 §5-6, 174項 57-101,126-133
// ─────────────────────────────────────────────────────────────────────────────

// Common order base (Single Table + detail JSON). APPEND-ONLY content (triggers).
model Order {
  id                String      @id @default(cuid())
  orderNo           String      @unique
  patientId         String
  encounterId       String
  sessionId         String?
  orderType         OrderType
  classification    String?
  departmentId      String
  ordererUserId     String
  responsibleUserId String?
  status            OrderStatus @default(DRAFT)
  isUrgent          Boolean     @default(false)
  scheduledDate     DateTime?
  detail            Json
  doSourceOrderId   String?
  setId             String?
  version           Int         @default(1)
  previousVersionId String?     @unique
  supersededById    String?     @unique
  isLatest          Boolean     @default(true)
  consentDocId      String?
  createdAt         DateTime    @default(now())

  patient         Patient          @relation(fields: [patientId], references: [id])
  encounter       Encounter        @relation(fields: [encounterId], references: [id])
  previousVersion Order?           @relation("OrderVersion", fields: [previousVersionId], references: [id])
  nextVersion     Order?           @relation("OrderVersion")
  reception       OrderReception?
  executions      OrderExecution[]
  prescription    Prescription?
  labResults      LabResult[]

  @@index([encounterId, orderType, scheduledDate])
  @@index([status, departmentId])
  @@index([patientId, isLatest])
}

model OrderReception {
  id               String   @id @default(cuid())
  orderId          String   @unique
  receivedByUserId String
  receivedAt       DateTime @default(now())
  order            Order    @relation(fields: [orderId], references: [id])
}

model OrderExecution {
  id               String    @id @default(cuid())
  orderId          String
  executedByUserId String
  executedAt       DateTime  @default(now())
  result           Json?
  approvedByUserId String?
  approvedAt       DateTime?
  threePointAuth   Json? // 患者/薬剤/看護師 barcode verification
  order            Order     @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

model Prescription {
  id             String       @id @default(cuid())
  orderId        String       @unique
  patientId      String
  encounterId    String
  status         String       @default("proposed") // proposed|rule_checked|doctor_confirmed|dispensed
  dispenseType   DispenseType @default(IN_HOUSE)
  issuedByUserId String
  issuedAt       DateTime?
  createdAt      DateTime     @default(now())

  order     Order                  @relation(fields: [orderId], references: [id])
  items     PrescriptionItem[]
  checks    RuleCheckResult[]
  overrides PrescriptionOverride[]
}

model PrescriptionItem {
  id             String       @id @default(cuid())
  prescriptionId String
  drugProductId  String
  dosePerTime    Float
  doseUnit       String
  timesPerDay    Float
  days           Int
  route          String
  usageCode      String?
  dispenseType   DispenseType @default(IN_HOUSE) // 院内/院外 — FR-RX-01
  isTemporary    Boolean      @default(false) // 臨時処方
  isOnePackage   Boolean      @default(false) // 一包化指示
  isOffLabel     Boolean      @default(false) // 適応外フラグ
  comment        String?
  prescription   Prescription @relation(fields: [prescriptionId], references: [id])
  drug           DrugProduct  @relation(fields: [drugProductId], references: [id])

  @@index([prescriptionId])
}

// 4大+拡張チェック結果 (1:N). checkedBy can never be AI (enum has no AI member).
model RuleCheckResult {
  id             String        @id @default(cuid())
  prescriptionId String
  orderId        String?
  checkType      RuleCheckType
  result         RuleResult
  checkedBy      RuleCheckedBy @default(STATIC_DB)
  severityNote   String?
  details        Json // matched drug, patient condition, source citation, master version
  masterVersion  String?
  createdAt      DateTime      @default(now())
  prescription   Prescription  @relation(fields: [prescriptionId], references: [id])

  @@index([prescriptionId])
}

model PrescriptionOverride {
  id                  String       @id @default(cuid())
  prescriptionId      String
  ruleCheckResultId   String
  overriddenByUserId  String
  reason              String
  countersignByUserId String?
  createdAt           DateTime     @default(now())
  prescription        Prescription @relation(fields: [prescriptionId], references: [id])

  @@index([prescriptionId])
}

// 検査結果 (FR-LAB-01) — 数値/基準値判定/採取日 + トレンド source.
// APPEND-ONLY: db/triggers.sql blocks UPDATE/DELETE (検査結果は確定後不変).
// Corrections issue a new resulted row; status carries FINAL/PRELIMINARY/CORRECTED.
model LabResult {
  id           String          @id @default(cuid())
  patientId    String
  encounterId  String?
  examMasterId String?
  orderId      String?
  value        Float?
  valueText    String?
  unit         String?
  refLow       Float?
  refHigh      Float?
  flag         String? // H | L | HH | LL | abnormal flag
  collectedAt  DateTime?
  resultedAt   DateTime?
  status       String          @default("FINAL") // FINAL | PRELIMINARY | CORRECTED
  source       DrugDataSource?
  provenance   Json?
  createdAt    DateTime        @default(now())

  patient    Patient     @relation(fields: [patientId], references: [id])
  encounter  Encounter?  @relation(fields: [encounterId], references: [id])
  examMaster ExamMaster? @relation(fields: [examMasterId], references: [id])
  order      Order?      @relation(fields: [orderId], references: [id])

  @@index([patientId, examMasterId, collectedAt])
}

// 警告無効化設定 (FR-RXSAFE-05 / G13). 処置行為・医薬品・チェック種類・レベル単位で
// 警告を抑制し表示先(カルテ/要確認レセプト)を制御。更新可のため append-only 対象外。
// ALLERGY / ABSOLUTE は抑制対象外 (アプリ層で担保)。
model RuleSuppression {
  id              String         @id @default(cuid())
  clinicId        String?
  scope           String // PROCEDURE | DRUG | DRUG_CLASS | CHECK_TYPE
  targetKey       String // 対象キー (procedure code / drug id / class / checkType)
  checkType       RuleCheckType?
  minLevel        String? // WARNING 以上を抑制する閾値
  showIn          String         @default("CHART") // CHART | RECEIPT_REVIEW
  createdByUserId String?
  createdAt       DateTime       @default(now())

  @@index([clinicId, scope])
}

// ─────────────────────────────────────────────────────────────────────────────
// Drug master (M06/M07) — code system (full auto import) + safety (provenance-strict)
// ─────────────────────────────────────────────────────────────────────────────

model DrugProduct {
  id                  String    @id @default(cuid())
  receiptCode         String    @unique // レセプト電算 医薬品コード
  yjCode              String?
  hotCode             String?
  gs1Code             String?
  gtinUnit            String?
  brandName           String
  brandNameKana       String?
  genericName         String?
  strengthValue       Float?
  strengthUnit        String?
  dosageForm          String
  administrationRoute String // 内服 | 外用 | 注射 | その他
  unitCode            String?
  nhiPrice            Float?
  nhiPriceDate        DateTime?
  isGeneric           Boolean   @default(false)
  isNarcotic          Boolean   @default(false)
  isPsychotropic      Boolean   @default(false)
  isPoison            Boolean   @default(false)
  isPowerfulDrug      Boolean   @default(false)
  isBiological        Boolean   @default(false)
  atcCode             String?
  marketingStatus     String    @default("ON_MARKET")
  sourceMasterVersion String
  provenance          Json // {source, sourceFile, importedAt, masterVersion}
  createdAt           DateTime  @default(now())

  ingredients DrugProductIngredient[]
  rxItems     PrescriptionItem[]

  @@index([yjCode])
  @@index([hotCode])
  @@index([atcCode])
}

model DrugIngredient {
  id                 String                  @id @default(cuid())
  ingredientCode     String                  @unique
  ingredientName     String
  ingredientNameKana String?
  ingredientNameEn   String?
  keggDrugId         String? // reference only — never used for judgement
  saltVariantOfId    String?
  saltVariantOf      DrugIngredient?         @relation("SaltVariant", fields: [saltVariantOfId], references: [id])
  saltVariants       DrugIngredient[]        @relation("SaltVariant")
  products           DrugProductIngredient[]
}

model DrugProductIngredient {
  id            String         @id @default(cuid())
  drugProductId String
  ingredientId  String
  amountValue   Float?
  amountUnit    String?
  isActive      Boolean        @default(true)
  product       DrugProduct    @relation(fields: [drugProductId], references: [id])
  ingredient    DrugIngredient @relation(fields: [ingredientId], references: [id])

  @@unique([drugProductId, ingredientId])
}

model DrugCodeCrosswalk {
  id               String  @id @default(cuid())
  receiptCode      String
  hotCode          String?
  yjCode           String?
  ingredientCode   String?
  matchMethod      String // exact | medis_table | manual
  confidence       String // high | medium | low
  verifiedByUserId String?
  provenance       Json

  @@index([receiptCode])
}

// ── Safety tables: provenance NOT NULL, source ∈ DrugDataSource (NO AI member) ──

model DrugIndication {
  id                    String         @id @default(cuid())
  targetKind            DrugTargetKind
  targetId              String
  indicationText        String
  icd10Codes            String[]       @default([])
  isInsuranceApplicable Boolean        @default(true)
  conditionNote         String?
  source                DrugDataSource
  sourceCitation        String
  validFrom             DateTime       @default(now())
  validTo               DateTime?
  reviewedByUserId      String?
  reviewedAt            DateTime?
  isSeed                Boolean        @default(false)
  isProvisional         Boolean        @default(false)
  createdAt             DateTime       @default(now())

  @@index([targetKind, targetId])
}

model DrugDosage {
  id                String           @id @default(cuid())
  targetKind        DrugTargetKind
  targetId          String
  population        DosagePopulation @default(ADULT)
  route             String
  usualDoseSingle   Float?
  usualDoseDaily    Float?
  maxDoseSingle     Float?
  maxDoseDaily      Float?
  maxDosePeriod     Float?
  periodUnit        String?
  weightBased       Boolean          @default(false)
  dosePerKgSingle   Float?
  dosePerKgDaily    Float?
  ageMinDays        Int?
  ageMaxDays        Int?
  renalAdjustment   Json?
  hepaticAdjustment Json?
  dosageText        String?
  source            DrugDataSource
  sourceCitation    String
  validFrom         DateTime         @default(now())
  validTo           DateTime?
  reviewedByUserId  String?
  reviewedAt        DateTime?
  isSeed            Boolean          @default(false)
  isProvisional     Boolean          @default(false)
  createdAt         DateTime         @default(now())

  @@index([targetKind, targetId])
}

model DrugContraindication {
  id                String              @id @default(cuid())
  targetKind        DrugTargetKind
  targetId          String
  severity          ContraSeverity
  conditionType     ContraConditionType
  icd10Codes        String[]            @default([])
  ageMinDays        Int?
  ageMaxDays        Int?
  targetDrugOrClass Json?
  conditionText     String
  rationale         String?
  source            DrugDataSource
  sourceCitation    String
  validFrom         DateTime            @default(now())
  validTo           DateTime?
  reviewedByUserId  String?
  reviewedAt        DateTime?
  isSeed            Boolean             @default(false)
  isProvisional     Boolean             @default(false)
  createdAt         DateTime            @default(now())

  @@index([targetKind, targetId])
}

model DrugInteraction {
  id               String                 @id @default(cuid())
  subjectKind      DrugTargetKind
  subjectId        String
  counterpartType  InteractionCounterpart
  counterpartRef   Json
  severity         InteractionSeverity
  mechanism        String?
  clinicalEffect   String?
  management       String?
  source           DrugDataSource
  sourceCitation   String
  validFrom        DateTime               @default(now())
  validTo          DateTime?
  reviewedByUserId String?
  reviewedAt       DateTime?
  isSeed           Boolean                @default(false)
  isProvisional    Boolean                @default(false)
  createdAt        DateTime               @default(now())

  @@index([subjectKind, subjectId])
}

// Append-only safety-data review trail (真正性).
model DrugSafetyReviewLog {
  id               String   @id @default(cuid())
  entityTable      String
  entityId         String
  action           String // create | supersede | retire
  before           Json?
  after            Json?
  reviewedByUserId String?
  reason           String?
  sourceCitation   String?
  createdAt        DateTime @default(now())

  @@index([entityTable, entityId])
}

// ── Other masters ──

model ExamMaster {
  id                  String  @id @default(cuid())
  code                String  @unique
  name                String
  jlac10              String?
  category            String
  specimenType        String?
  refLow              Float?
  refHigh             Float?
  unit                String?
  points              Int? // 保険点数概算 (display-only; 算定はレセコン委譲＝正本ではない) — EXM1/FR-EXM-01
  sourceMasterVersion String
  provenance          Json

  labResults LabResult[]
}

model DiseaseMaster {
  id                  String         @id @default(cuid())
  code                String         @unique // MEDIS標準病名コード
  name                String
  icd10               String[]       @default([])
  isConfidential      Boolean        @default(false)
  source              DrugDataSource
  sourceMasterVersion String
}

model MasterVersion {
  id            String     @id @default(cuid())
  masterType    MasterType
  source        String
  sourceRelease String
  validFrom     DateTime
  validTo       DateTime?
  importedAt    DateTime   @default(now())
  checksum      String?

  @@index([masterType, validFrom])
}

model ImportRun {
  id        String       @id @default(cuid())
  source    String
  startedAt DateTime     @default(now())
  endedAt   DateTime?
  counts    Json?
  checksum  String?
  status    ImportStatus @default(RUNNING)
}

// ─────────────────────────────────────────────────────────────────────────────
// 病名・転帰 / 紹介状 / 文書 / 退院サマリ (M04/M12) — 174項 19-22,117,166-168
// ─────────────────────────────────────────────────────────────────────────────

enum DiagnosisStatus {
  ACTIVE
  RESOLVED
  DELETED
}

enum DiseaseOutcome {
  CURED
  IMPROVED
  UNCHANGED
  TRANSFERRED
  DECEASED
  STOPPED
}

model PatientDiagnosis {
  id               String          @id @default(cuid())
  patientId        String
  encounterId      String?
  masterCode       String?
  displayName      String
  icd10            String?
  departmentId     String?
  isMain           Boolean         @default(false)
  isSuspected      Boolean         @default(false)
  acuteChronic     String? // ACUTE | CHRONIC
  startDate        DateTime        @default(now())
  outcome          DiseaseOutcome?
  outcomeDate      DateTime?
  forBilling       Boolean         @default(true)
  status           DiagnosisStatus @default(ACTIVE)
  recordedByUserId String
  createdAt        DateTime        @default(now())

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([patientId, status])
}

enum ReferralDirection {
  INBOUND
  OUTBOUND
}

enum ReferralStatus {
  DRAFT
  PRINTED
  SENT
  AWAITING_REPLY
  REPLY_RECEIVED
  CLOSED
}

model Referral {
  id              String            @id @default(cuid())
  patientId       String?
  direction       ReferralDirection @default(OUTBOUND)
  partnerFacility String
  partnerDoctor   String?
  internalDeptId  String?
  internalUserId  String?
  purpose         String
  chiefComplaint  String?
  diseaseState    String?
  status          ReferralStatus    @default(DRAFT)
  desiredVisitOn  DateTime?
  replyText       String?
  createdByUserId String
  createdAt       DateTime          @default(now())

  patient Patient? @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([status])
}

model ClinicalDocument {
  id              String   @id @default(cuid())
  patientId       String?
  encounterId     String?
  docType         String // 紹介状|同意書|説明書|退院サマリ|スキャン|院内文書
  templateId      String?
  title           String
  format          String   @default("TEXT") // TEXT|WORD|PDF|SCAN_IMAGE
  body            String?
  storageUrl      String?
  scannedPages    Int?
  ocrText         String?
  version         Int      @default(1)
  createdByUserId String
  createdAt       DateTime @default(now())

  @@index([patientId, docType])
}

enum SummaryStatus {
  DRAFT
  COMPLETED
}

model DischargeSummary {
  id              String        @id @default(cuid())
  patientId       String
  admissionRef    String?
  status          SummaryStatus @default(DRAFT)
  approvalStatus  String        @default("UNAPPROVED") // UNAPPROVED|APPROVED
  authorUserId    String
  approverUserId  String?
  approvedAt      DateTime?
  admissionCourse String?
  presentIllness  String?
  hospitalCourse  String?
  dischargePlan   String?
  version         Int           @default(1)
  createdAt       DateTime      @default(now())

  @@index([patientId])
}

// ─────────────────────────────────────────────────────────────────────────────
// 病床管理 (WRD1) — FR-WRD-01. 入退院 (Admission) と病床割当・転室履歴 (BedAssignment)。
// 既存 Ward/Room/Bed/Encounter リレーションと整合。在床の「現在地」は
// Encounter.currentBedId、移動の「歴」は BedAssignment（追記中心）で表す。
// 33WP 実装では admitPatient / transferPatient / dischargePatient が割当病床コード等を
// 監査 detail に退避していた箇所を、本モデルで本番永続化する。
// ─────────────────────────────────────────────────────────────────────────────

// 入院エピソード。1 入院 = 1 Admission（INPATIENT Encounter に 1:1）。
// 更新可（status / dischargedAt の付与）— append-only 対象外（移動の真正性は BedAssignment が担保）。
model Admission {
  id               String          @id @default(cuid())
  patientId        String
  encounterId      String          @unique
  wardId           String
  admittedAt       DateTime        @default(now())
  dischargedAt     DateTime?
  status           AdmissionStatus @default(ADMITTED)
  admissionReason  String?
  dischargeReason  String?
  admittedByUserId String?
  createdAt        DateTime        @default(now())

  patient   Patient   @relation(fields: [patientId], references: [id])
  encounter Encounter @relation(fields: [encounterId], references: [id])
  ward      Ward      @relation(fields: [wardId], references: [id])

  @@index([patientId, status])
  @@index([wardId, status])
}

// 病床割当・転室の履歴（追記専用）。入院初回割当・転棟・転科・転室・退院解放を 1 行ずつ積む。
// releasedAt が NULL の行 = 現在有効な割当。所在管理は法定（真正性）→ db/triggers.sql で UPDATE/DELETE 禁止。
model BedAssignment {
  id               String        @id @default(cuid())
  encounterId      String
  patientId        String
  wardId           String
  roomId           String?
  bedId            String?
  bedCode          String? // bed 行が未マスタ化でも所在を残せるよう生コードも保持
  reason           BedMoveReason @default(ADMISSION)
  note             String?
  assignedAt       DateTime      @default(now())
  releasedAt       DateTime? // 次の移動 / 退院でこの割当が終了した時刻（履歴クローズ）
  assignedByUserId String?
  createdAt        DateTime      @default(now())

  encounter Encounter @relation(fields: [encounterId], references: [id])
  patient   Patient   @relation(fields: [patientId], references: [id])
  ward      Ward      @relation(fields: [wardId], references: [id])
  room      Room?     @relation(fields: [roomId], references: [id])
  bed       Bed?      @relation(fields: [bedId], references: [id])

  @@index([encounterId, assignedAt])
  @@index([patientId, assignedAt])
  @@index([bedId])
}

// ─────────────────────────────────────────────────────────────────────────────
// 看護 (WRD2) — FR-WRD-02. 看護計画 (NursingPlan + Item) ＋ 褥瘡 DESIGN-R (PressureUlcer)。
// 33WP 実装では ClinicalDocument(docType=看護計画/褥瘡DESIGN-R) で代替していた箇所を本番化。
// 計画は改訂運用のため更新可（append-only 対象外）。褥瘡評価は記録性 → 追記専用。
// ─────────────────────────────────────────────────────────────────────────────

// 看護計画（看護診断 → 期待される成果 → 看護介入(O-T-E) → 評価）。更新可。
model NursingPlan {
  id           String            @id @default(cuid())
  patientId    String
  encounterId  String?
  title        String?
  status       NursingPlanStatus @default(ACTIVE)
  startedOn    DateTime          @default(now())
  evaluatedOn  DateTime?
  authorUserId String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  patient Patient           @relation(fields: [patientId], references: [id])
  items   NursingPlanItem[]

  @@index([patientId, status])
}

model NursingPlanItem {
  id        String              @id @default(cuid())
  planId    String
  kind      NursingPlanItemKind
  content   String
  sortOrder Int                 @default(0)
  createdAt DateTime            @default(now())

  plan NursingPlan @relation(fields: [planId], references: [id])

  @@index([planId])
}

// 褥瘡 DESIGN-R®2020 評価（各項目の重症度コード＋点数、合計、判定日）。追記専用（記録の真正性）。
// 合計 (totalScore) は Depth を除く 6 項目の合計（DESIGN-R 通則）。訂正は新規行で表現。
// db/triggers.sql で UPDATE/DELETE 禁止。
model PressureUlcer {
  id                String             @id @default(cuid())
  patientId         String
  encounterId       String?
  site              String?
  depth             PressureUlcerDepth @default(DU)
  depthScore        Int                @default(0) // 重症度合計には含めない
  exudateScore      Int                @default(0)
  sizeScore         Int                @default(0)
  inflammationScore Int                @default(0)
  granulationScore  Int                @default(0)
  necroticScore     Int                @default(0)
  pocketScore       Int                @default(0)
  totalScore        Int                @default(0) // Depth 除く 6 項目合計
  note              String?
  assessedOn        DateTime           @default(now()) // 判定日
  assessedByUserId  String
  createdAt         DateTime           @default(now())

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([patientId, assessedOn])
}

// ─────────────────────────────────────────────────────────────────────────────
// 救急 (ER1) — FR-ER-01. 救急受診の主訴/搬送方法/同意区分/トリアージ詳細。
// TriageLevel は既存 enum / Encounter.triageLevel を再利用。受付時点の固定情報を
// EmergencyVisit に 1:1 で持つ（再トリアージは Encounter.triageLevel を更新＝既存挙動）。
// 33WP 実装では registerEmergency が chiefComplaint/consentType を監査 detail に退避していた箇所を本番化。
// 受付記録（救急時点の事実）として追記専用。db/triggers.sql で UPDATE/DELETE 禁止。
// ─────────────────────────────────────────────────────────────────────────────
model EmergencyVisit {
  id                   String       @id @default(cuid())
  encounterId          String       @unique
  patientId            String? // 身元不明（仮ID）受付では NULL 可
  chiefComplaint       String?
  arrivalMethod        String? // 救急車/ドクターカー/独歩 等（Encounter.arrivalMethod の確定写し）
  triageLevelAtArrival TriageLevel? // 受付時トリアージ（再トリアージ前の初期値を保全）
  consentType          ConsentType?
  isUnidentified       Boolean      @default(false)
  arrivedAt            DateTime     @default(now())
  receivedByUserId     String?
  createdAt            DateTime     @default(now())

  encounter Encounter @relation(fields: [encounterId], references: [id])

  @@index([patientId])
}

// ─────────────────────────────────────────────────────────────────────────────
// 在宅 (HOM1) — FR-HOM-01. 訪問録（HomeVisit）。訪問スケジュールは既存 Appointment(kind=HOMECARE)
// ＋ Encounter(HOMECARE) を再利用（schema を増やさない）。訪問録本文/バイタル/オフライン同期は
// HomeVisit に永続化。33WP 実装では syncOfflineRecords が note/vitals を監査 detail / SS-MIX2 へのみ
// 退避していた箇所を本番化。訪問録は記録性 → 追記専用。db/triggers.sql で UPDATE/DELETE 禁止。
// ※ ClinicalNote 経由で残す場合は NoteType.HOMECARE を利用可（本モデルはモバイル/オフライン同期の一次受け）。
// ─────────────────────────────────────────────────────────────────────────────
model HomeVisit {
  id               String             @id @default(cuid())
  patientId        String
  encounterId      String?
  appointmentId    String? // 訪問予定（Appointment）から起こした場合の参照
  visitKind        HomeVisitKind      @default(DOCTOR)
  visitedAt        DateTime           @default(now())
  note             String? // S/O/A/P を 1 本にまとめた訪問記録本文
  vitals           String? // 任意・自由記述（BP/HR/SpO2/BT 等）
  syncState        HomeVisitSyncState @default(SYNCED)
  clientId         String? // オフライン端末が採番した冪等同期キー（重複同期防止）
  recordedByUserId String
  createdAt        DateTime           @default(now())

  patient   Patient    @relation(fields: [patientId], references: [id])
  encounter Encounter? @relation(fields: [encounterId], references: [id])

  // 端末由来の冪等同期：同一 clientId は 1 度しか確定させない。
  @@unique([clientId])
  @@index([patientId, visitedAt])
  @@index([appointmentId])
}

// ─────────────────────────────────────────────────────────────────────────────
// 処方/オーダセット (RX1/RX2) — FR-RX-02. 処方セット・オーダセット (OrderSet + Item) と
// 用法マスタ (UsageMaster)。Order.setId（既存）から参照する識別子の発番元。
// 33WP 実装では「処方セットの保存/呼出」を Order.setId 文字列のみで運用していた箇所を本番化。
// 設定（マスタ/テンプレート）系のため更新可（append-only 対象外）。
// ─────────────────────────────────────────────────────────────────────────────

// 処方セット / オーダセットのヘッダ。発行時に Order.setId へこの id を載せてトレースする。
model OrderSet {
  id              String       @id @default(cuid())
  clinicId        String?
  departmentId    String?
  ownerUserId     String? // DOCTOR スコープ（個人セット）の所有者。NULL = 共有
  kind            OrderSetKind @default(RX)
  code            String?
  name            String
  description     String?
  isActive        Boolean      @default(true)
  sortOrder       Int          @default(0)
  createdByUserId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  items OrderSetItem[]

  @@index([clinicId, kind])
  @@index([ownerUserId])
}

// セット明細。RX セットは薬剤＋用法＋用量、ORDER セットは任意オーダ種別を payload(detail) で保持。
model OrderSetItem {
  id            String     @id @default(cuid())
  setId         String
  orderType     OrderType? // ORDER セット時のオーダ種別（RX セットでは RX 固定/NULL 可）
  drugProductId String? // RX セットの薬剤
  examMasterId  String? // 検査セットの検査項目
  usageCode     String? // 用法（UsageMaster.code を参照可）
  dosePerTime   Float?
  doseUnit      String?
  timesPerDay   Float?
  days          Int?
  route         String?
  detail        Json? // ORDER セットの自由 payload（注射/処置 等）
  sortOrder     Int        @default(0)
  createdAt     DateTime   @default(now())

  set OrderSet @relation(fields: [setId], references: [id])

  @@index([setId])
}

// 用法マスタ（内服/頓服/外用・コード・表示）。PrescriptionItem.usageCode / OrderSetItem.usageCode の参照元。
// 更新可（マスタ運用）。
model UsageMaster {
  id                 String        @id @default(cuid())
  clinicId           String?
  code               String        @unique
  displayName        String // 表示名（例: 毎食後 / 就寝前 / 頓用 / 外用）
  category           UsageCategory @default(INTERNAL)
  timing             String? // タイミング自由記述（例: 朝・昼・夕 食後）
  defaultTimesPerDay Float?
  isAsNeeded         Boolean       @default(false) // 頓服（日数任意判定に使用）
  isActive           Boolean       @default(true)
  sortOrder          Int           @default(0)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([clinicId, category])
}

// ─────────────────────────────────────────────────────────────────────────────
// パスワード変更履歴 (ADM1) — FR-SEC-06 / 別紙1 §1.1. 利用者管理のパスワード初期化・変更を
// 履歴として残す（StaffCredential は現在値のみ保持のため、変更の歴を本モデルで補完）。
// 33WP 実装では resetPassword 等が監査にのみ残していた変更歴を本番化。
// 履歴の真正性 → 追記専用。db/triggers.sql で UPDATE/DELETE 禁止。平文/ハッシュは保持しない。
// ─────────────────────────────────────────────────────────────────────────────
model PasswordChangeHistory {
  id              String   @id @default(cuid())
  userId          String
  changedAt       DateTime @default(now())
  changedByUserId String? // 本人なら userId と同値 / 管理者初期化なら管理者の id
  reason          String? // RESET / EXPIRED / SELF_CHANGE / UNLOCK 等
  mustChangeSet   Boolean  @default(false) // この変更で mustChange を立てたか（初期化）
  terminalId      String?

  user      StaffUser  @relation("PwChangeUser", fields: [userId], references: [id])
  changedBy StaffUser? @relation("PwChangeActor", fields: [changedByUserId], references: [id])

  @@index([userId, changedAt])
}
