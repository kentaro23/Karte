{
  "name": "medixus-karte",
  "private": true,
  "version": "0.1.0",
  "description": "Medixus カルテ — 病院グレード電子カルテ (hospital-grade Japanese EMR)",
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev --filter=@medixus/emr-web",
    "dev:clean": "rm -rf apps/emr-web/.next .turbo && turbo run dev --filter=@medixus/emr-web",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @medixus/db generate",
    "db:migrate": "pnpm --filter @medixus/db migrate",
    "db:push": "pnpm --filter @medixus/db push",
    "db:triggers": "pnpm --filter @medixus/db triggers",
    "seed": "pnpm --filter @medixus/seed seed",
    "verify": "pnpm --filter @medixus/seed verify",
    "import:drugs": "bash scripts/import-drugs.sh",
    "export:drugs:bundle": "pnpm --filter @medixus/seed exec tsx export-bundle.ts",
    "import:drugs:bundle": "pnpm --filter @medixus/seed exec tsx import-bundle.ts",
    "pg:init": "bash scripts/pg.sh init",
    "pg:start": "bash scripts/pg.sh start",
    "pg:stop": "bash scripts/pg.sh stop",
    "pg:status": "bash scripts/pg.sh status",
    "setup": "bash scripts/setup.sh"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "prisma", "esbuild"]
  }
}
