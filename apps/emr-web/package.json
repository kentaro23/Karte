{
  "name": "@medixus/emr-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3000",
    "prebuild": "pnpm --filter @medixus/db generate",
    "build": "NEXT_DIST_DIR=.next-build next build",
    "start": "NEXT_DIST_DIR=.next-build next start -p 3000",
    "typecheck": "tsc --noEmit",
    "lint": "next lint"
  },
  "dependencies": {
    "@medixus/db": "workspace:*",
    "@medixus/domain": "workspace:*",
    "@medixus/auth": "workspace:*",
    "@medixus/authz": "workspace:*",
    "@medixus/audit": "workspace:*",
    "@medixus/order-checks": "workspace:*",
    "@medixus/rule-engine": "workspace:*",
    "@medixus/master-import": "workspace:*",
    "@medixus/ui": "workspace:*",
    "next": "15.0.3",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "@types/node": "^22.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^3.4.13",
    "postcss": "^8.4.47",
    "autoprefixer": "^10.4.20"
  }
}
